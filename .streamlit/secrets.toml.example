# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is in .gitignore and will never be committed.
#
# On Streamlit Cloud: paste these key=value pairs into the "Secrets" panel
# (App Settings → Secrets) — no need for the file itself.

FOOTBALL_API_KEY = "your-football-data-org-key-here"
ADMIN_PASSWORD   = "your-admin-password-here"
